# EarthPulse — environment variables
# Copy this file to `.env.local` in the same folder (`earthpulse/`) and paste your keys.
# Next.js loads `.env.local` automatically (do not commit real secrets).

# ── OpenAI (place research fallback) ───────────────────────────────
# Powers: POST /api/place-research — web search + structured JSON brief.
# Default chain: Backboard → OpenAI → offline brief. (Gemini for place-research remains opt-in below.)
# Create a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=PASTE_YOUR_OPENAI_KEY_HERE
# Optional — any Responses-API model that supports the web_search tool (default gpt-4o)
# OPENAI_RESEARCH_MODEL=gpt-4o
# Later, if you want OpenAI → Gemini → offline when OpenAI fails, set:
# PLACE_RESEARCH_USE_GEMINI=true

# ── Backboard (place research primary) ─────────────────────────────
# Powers: POST /api/place-research — persistent memory + context across repeat requests for same place.
# Create a key: https://app.backboard.io/
BACKBOARD_API_KEY=PASTE_YOUR_BACKBOARD_API_KEY_HERE
# Optional: pin to an existing assistant ID from Backboard dashboard
# BACKBOARD_PLACE_ASSISTANT_ID=PASTE_ASSISTANT_ID_HERE

# ── Google Gemini (optional) ───────────────────────────────────────
# Powers: POST /api/plan  (7-day climate copilot on analyze page)
# Powers: POST /api/dead-zone-story  (narrative on dead-zone detail page)
# Powers: POST /api/dead-zone-reading  (Gemini + Google Search → real article links on detail page)
# If Gemini is rate-limited/quota-exhausted, routes can fall back to Anthropic when configured below.
# Optional for /api/place-research only when PLACE_RESEARCH_USE_GEMINI=true
# Create a key: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE

# Optional — model id (defaults to gemini-2.0-flash in code if unset)
# GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic (Gemini fallback for dead-zone APIs) ─────────────────
# Used when Gemini quota/rate limits are hit on:
# - POST /api/dead-zone-story
# - POST /api/dead-zone-reading
# Create a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=PASTE_YOUR_ANTHROPIC_KEY_HERE
# Optional — defaults to claude-3-5-haiku-latest
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ── OpenWeather (optional) ───────────────────────────────────────
# Powers: real air-pollution (AQI) in GET /api/analyze
# Without it, EarthPulse still runs using estimated AQI from other signals.
# Sign up: https://openweathermap.org/api
OPENWEATHER_API_KEY=PASTE_YOUR_OPENWEATHER_KEY_HERE

# Place research already surfaces headlines when OPENAI_API_KEY is set (web_search in Responses API).
