# EarthPulse — copy to `.env.local` for local dev, or set the same keys in Vercel → Project → Settings → Environment Variables.
# Do not put real secrets in this file; it is safe to commit.

# ── OpenAI (optional) — POST /api/place-research
OPENAI_API_KEY=
# OPENAI_RESEARCH_MODEL=gpt-4o
# PLACE_RESEARCH_USE_GEMINI=true

# ── Backboard (optional) — POST /api/place-research with persistent memory/context
BACKBOARD_API_KEY=
# Optional: reuse a pre-created assistant from your Backboard dashboard
# BACKBOARD_PLACE_ASSISTANT_ID=

# ── Google Gemini (optional) — /api/plan, /api/dead-zone-story, /api/dead-zone-reading
GOOGLE_GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ── OpenWeather (optional) — GET /api/analyze AQI
OPENWEATHER_API_KEY=
